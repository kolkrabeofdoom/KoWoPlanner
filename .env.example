# Kopieren nach .env und Werte setzen (NIEMALS die echte .env committen!)

# Geheimer Schlüssel zum Signieren der JWT-Tokens.
# Erzeugen z.B. mit: openssl rand -base64 48
JWT_SECRET=

# Passwort für den PostgreSQL-Benutzer "postgres"
POSTGRES_PASSWORD=

# Optional: Passwort für die Demo-Benutzer beim Seeding (Default: PASSWORT)
# SEED_PASSWORD=
